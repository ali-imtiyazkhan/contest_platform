generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  User
  Admin
}

enum ContestCategory {
  MathLogic
  Writing
  GeneralKnowledge
  TechCoding
}

enum Difficulty {
  Beginner
  Intermediate
  Advanced
  Elite
}

enum ContextStatus {
  Pending
  Generating
  Completed
  Failed
}

enum SubmissionStatus {
  Pending
  Judging
  Accepted
  Rejected
}

enum ParticipationMode {
  Solo
  Team
}

enum DuelStatus {
  Pending
  Active
  Completed
  Cancelled
}

enum ChallengeCategory {
  Debugging
  UIFix
  APIDesign
  Algorithms
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  password    String?
  role        Role    @default(User)
  rating      Int     @default(1200)
  displayName String? 
  country     String?  
  avatarColor String  @default("#4f86f7")
  
  provider    String?
  providerId  String?
  avatarUrl   String?

  contestSubmissions  ContestSubmission[]
  leaderboard         Leaderboard[]
  ratingHistories     RatingHistory[]
  contestParticipants ContestParticipant[]
  ownedTeams          Team[]              @relation("TeamOwner")
  teamMemberships     TeamMembership[]
  chatMessages        ChatMessage[]
  duelsAsPlayer1      Duel[]              @relation("Player1")
  duelsAsPlayer2      Duel[]              @relation("Player2")
  duelSubmissions     DuelSubmission[]
}

model Contest {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())

  category        ContestCategory @default(MathLogic)
  difficulty      Difficulty      @default(Beginner)
  prize           Int             @default(0)
  maxParticipants Int             @default(1000)
  host            String?
  tags            String[]        @default([])
  participationMode ParticipationMode @default(Solo)

  contestToChallengeMapping ContestToChallengeMapping[]
  leaderboard               Leaderboard[]
  ratingHistories           RatingHistory[]
  contestParticipants       ContestParticipant[]
  chatMessages              ChatMessage[]

  @@index([startTime])
  @@index([endTime])
}

model Challenge {
  id            String        @id @default(uuid())
  title         String
  question      String        @default("")
  hint          String?
  maxPoints     Int
  duration      Int           @default(0)
  description   String?
  createdAt     DateTime      @default(now())
  contextStatus ContextStatus @default(Pending)

  aiContext String?
  type      Difficulty?
  category  ChallengeCategory @default(Algorithms)

  contestToChallengeMapping ContestToChallengeMapping[]
  duels                     Duel[]

  @@index([createdAt])
}

model ContestToChallengeMapping {
  id          String @id @default(uuid())
  contestId   String
  challengeId String
  index       Int

  contest   Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  submissions ContestSubmission[]

  @@unique([contestId, challengeId])
}

model ContestSubmission {
  id                          String @id @default(uuid())
  submission                  String
  contestToChallengeMappingId String
  userId                      String
  teamId                      String?

  points    Int              @default(0)
  aiVerdict String?
  aiReason  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime?         @updatedAt  
  status    SubmissionStatus @default(Pending)

  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                      Team?                     @relation(fields: [teamId], references: [id])
  contestToChallengeMapping ContestToChallengeMapping @relation(fields: [contestToChallengeMappingId], references: [id], onDelete: Cascade)

  @@unique([contestToChallengeMappingId, userId])
  @@index([status, updatedAt]) 
}

model Team {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  ownerId     String
  createdAt   DateTime @default(now())

  owner       User              @relation("TeamOwner", fields: [ownerId], references: [id])
  members     TeamMembership[]
  leaderboard Leaderboard[]
  submissions ContestSubmission[]
  participants ContestParticipant[]

  @@index([inviteCode])
}

model TeamMembership {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  joinedAt  DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  userId    String
  contestId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId, createdAt])
}

model Leaderboard {
  id           String   @id @default(uuid())
  contestId    String
  userId       String?
  teamId       String?
  score        Int      @default(0)
  lastUpdated  DateTime? @updatedAt 

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@unique([contestId, teamId])
  @@index([contestId, score])
}

model RatingHistory {
  id        String   @id @default(uuid())
  userId    String
  contestId String
  before    Int
  after     Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ContestParticipant {
  id           String   @id @default(uuid())
  contestId    String
  userId       String
  teamId       String?
  registeredAt DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id])

  @@unique([contestId, userId])
  @@index([contestId])
}

model Duel {
  id          String     @id @default(uuid())
  player1Id   String
  player2Id   String
  challengeId String
  status      DuelStatus @default(Pending)
  startTime   DateTime?
  endTime     DateTime?
  winnerId    String?
  createdAt   DateTime   @default(now())

  player1     User             @relation("Player1", fields: [player1Id], references: [id])
  player2     User             @relation("Player2", fields: [player2Id], references: [id])
  challenge   Challenge        @relation(fields: [challengeId], references: [id])
  submissions DuelSubmission[]

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
}

model DuelSubmission {
  id         String           @id @default(uuid())
  duelId     String
  userId     String
  submission String
  points     Int              @default(0)
  status     SubmissionStatus @default(Pending)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime?        @updatedAt

  duel Duel @relation(fields: [duelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([duelId, userId])
}
